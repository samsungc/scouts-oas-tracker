# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local dev — use DATABASE_URL on Render)
DB_NAME=scoutdb
DB_USER=scouts
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (used to construct password reset links in emails)
FRONTEND_URL=http://localhost:5173

# S3 File Storage (set USE_S3=True in production)
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Email (Amazon SES) — AWS_ACCESS_KEY_ID/SECRET above are reused for SES auth
SES_FROM_EMAIL=noreply@mail.6rhventurers.ca
SES_REGION=us-east-2
